{
	"name": "@deebeetech/deebee-edms",
	"private": true,
	"version": "1.0.0",
	"packageManager": "pnpm@10.33.0",
	"description": "Complex configurable data editor for Supabase",
	"homepage": "https://github.com/deebee-tech/deebee-edms",
	"license": "MIT",
	"type": "module",
	"author": {
		"name": "Sandy Weatherby",
		"email": "unicornbeachdiaries@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/deebee-tech/deebee-edms"
	},
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:types": "tsx scripts/db_types.ts",
		"db:link": "tsx scripts/db_link.ts",
		"db:push": "tsx scripts/db_push.ts",
		"dev": "vite dev",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"spell": "cspell \"**/*.*\"",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"translate": "tsx scripts/clear_translations.ts && inlang machine translate --project ./project.inlang",
		"translate:machine": "inlang machine translate --project project.inlang",
		"translate:validate": "inlang validate --project ./project.inlang"
	},
	"devDependencies": {
		"@cspell/dict-es-es": "^3.0.8",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/figtree": "^5.2.10",
		"@hugeicons/core-free-icons": "^4.1.0",
		"@hugeicons/svelte": "^1.1.2",
		"@inlang/cli": "^3.1.9",
		"@inlang/paraglide-js": "^2.15.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@supabase/supabase-js": "^2.100.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24.12.0",
		"@vitest/browser-playwright": "^4.1.2",
		"bits-ui": "^2.16.4",
		"clsx": "^2.1.1",
		"cspell": "^9.7.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.58.2",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"supabase": "^2.84.5",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.5",
		"svelte-clerk": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitepress": "2.0.0-alpha.17",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0"
	}
}
