{
	"name": "@deebeetech/deebee-edms",
	"private": true,
	"version": "1.0.0",
	"packageManager": "pnpm@10.33.0",
	"description": "Complex configurable data editor for Supabase",
	"homepage": "https://github.com/deebee-tech/deebee-edms",
	"license": "MIT",
	"type": "module",
	"author": {
		"name": "Sandy Weatherby",
		"email": "unicornbeachdiaries@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/deebee-tech/deebee-edms"
	},
	"pnpm": {
		"overrides": {
			"@clerk/shared": "4.4.0"
		}
	},
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:types": "tsx scripts/db_types.ts",
		"db:link": "tsx scripts/db_link.ts",
		"db:push": "tsx scripts/db_push.ts",
		"dev": "vite dev",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"format": "prettier --write .",
		"lint": "eslint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"spell": "cspell \"**/*.*\"",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"translate": "tsx scripts/clear_translations.ts && inlang machine translate --project ./project.inlang",
		"translate:machine": "inlang machine translate --project project.inlang",
		"translate:validate": "inlang validate --project ./project.inlang"
	},
	"devDependencies": {
		"@clerk/localizations": "^4.3.0",
		"@clerk/shared": "4.4.0",
		"@clerk/ui": "^1.3.0",
		"@cspell/dict-es-es": "^3.0.8",
		"@deebeetech/array-helper": "latest",
		"@deebeetech/is-helper": "^3.0.0",
		"@deebeetech/sqleasy": "^1.0.2",
		"@deebeetech/string-builder": "^2.0.1",
		"@emoji-mart/data": "^1.2.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-code": "^5.2.7",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@fontsource/ibm-plex-serif": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"@inlang/cli": "^3.1.9",
		"@inlang/paraglide-js": "^2.15.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.59.1",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@supabase/supabase-js": "^2.101.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@tanstack/virtual-core": "^3.13.23",
		"@types/node": "^24.12.2",
		"@vitest/browser-playwright": "^4.1.2",
		"@xyflow/svelte": "^1.5.2",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"@zxcvbn-ts/language-en": "^3.0.2",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"country-flag-icons": "^1.6.15",
		"cspell": "^10.0.0",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"isomorphic-dompurify": "^3.7.1",
		"jsrepo": "^3.7.0",
		"layerchart": "^2.0.0-next.50",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"package-manager-detector": "^1.6.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.59.1",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"runed": "^0.37.1",
		"shiki": "^4.0.2",
		"supabase": "^2.85.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-clerk": "^1.1.1",
		"svelte-dnd-action": "^0.9.69",
		"svelte-easy-crop": "^5.0.1",
		"svelte-sonner": "^1.1.0",
		"svelte-tel-input": "^4.0.2",
		"svelte-toolbelt": "^0.10.6",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"valibot": "^1.3.1",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.5",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitepress": "2.0.0-alpha.17",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0",
		"yeezy-dates": "^1.1.0"
	}
}
